# Runtime
NODE_ENV=development
API_HOST=127.0.0.1
API_PORT=4100
WEB_PORT=3100
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:4100

# Local services
POSTGRES_PASSWORD=base_orchestrator
DATABASE_URL=postgresql://base_orchestrator:base_orchestrator@localhost:5435/base_orchestrator
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Network support
BASE_CHAIN_ID=8453
BASE_RPC_URL=https://mainnet.base.org
BASESCAN_BASE_URL=https://basescan.org

# Quotes
QUOTE_PROVIDER=mock
ZEROX_API_KEY=
ZEROX_SWAP_QUOTE_URL=
ZEROX_API_VERSION=v2

# Safety
# base-orchestrator defaults to dry-run mode. Keep this true unless you
# have explicitly audited and enabled live transaction paths in future phases.
DRY_RUN=true
REQUIRE_LIVE_CONFIRMATION=true
ALLOW_UNLIMITED_APPROVAL=false
AUTO_APPROVE=false
SCHEDULER_LIVE_EXECUTION=false

# Secret handling
# Never commit real values. Do not use seed phrases. Wallet private keys must
# be imported only into an encrypted vault once that feature exists.
VAULT_STORAGE_PATH=./data/vault.enc
MASTER_KEY_FILE=.local/master.key

# Optional integrations
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
