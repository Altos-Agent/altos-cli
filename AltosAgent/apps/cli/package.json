{
  "name": "@altos/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "Altos CLI - The command-line interface for Altos agent platform",
  "license": "Apache-2.0",
  "bin": {
    "altos": "./bin/altos.js"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "start": "node bin/altos.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@altos/core": "workspace:*",
    "@altos/ai": "workspace:*",
    "@altos/tui": "workspace:*",
    "@altos/tools": "workspace:*",
    "@altos/permissions": "workspace:*",
    "@altos/config": "workspace:*",
    "@altos/memory": "workspace:*",
    "@altos/plugins": "workspace:*",
    "@altos/code-index": "workspace:*",
    "@altos/skills": "workspace:*",
    "@altos/packages": "workspace:*",
    "@altos/mcp": "workspace:*",
    "@altos/local-api": "workspace:*",
    "@altos/cloud": "workspace:*",
    "@altos/sandbox": "workspace:*",
    "@altos/evals": "workspace:*"
  }
}
