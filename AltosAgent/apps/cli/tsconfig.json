{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "incremental": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "paths": {
      "@altos/evals": ["../../packages/evals/dist"],
      "@altos/evals/*": ["../../packages/evals/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", ".turbo", "src/**/*.test.ts"],
  "references": [
    {
      "path": "../../packages/skills"
    },
    {
      "path": "../../packages/packages"
    },
    {
      "path": "../../packages/plugins"
    },
    {
      "path": "../../packages/core"
    },
    {
      "path": "../../packages/ai"
    },
    {
      "path": "../../packages/tools"
    },
    {
      "path": "../../packages/code-index"
    },
    {
      "path": "../../packages/config"
    },
    {
      "path": "../../packages/sandbox"
    },
    {
      "path": "../../packages/evals"
    }
  ]
}
