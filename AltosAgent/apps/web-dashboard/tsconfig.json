{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "references": [{ "path": "../../packages/core" }, { "path": "../../packages/telemetry" }]
}
