{
  "name": "@altos/code-index",
  "version": "0.1.0",
  "type": "module",
  "description": "Altos code indexing and search - AST parsing, symbol maps, semantic search",
  "license": "Apache-2.0",
  "exports": {
    ".": "./dist/index.js",
    "./indexer": "./dist/indexer/index.js",
    "./search": "./dist/search/index.js",
    "./cli": "./dist/cli/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "bench:repo-map": "npx tsx src/bench/runner.ts"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.10",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "micromatch": "^4.0.8",
    "tree-sitter": "0.21.1",
    "tree-sitter-cli": "^0.26.9",
    "tree-sitter-javascript": "0.21.0",
    "tree-sitter-typescript": "0.21.1"
  }
}
