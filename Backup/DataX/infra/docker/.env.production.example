# =============================================================================
# DataLens Agent — PRODUCTION environment template.
#
# Copy to .env.production and FILL EVERY REQUIRED VALUE before deploying:
#   cp infra/docker/.env.production.example infra/docker/.env.production
#   chmod 0600 infra/docker/.env.production
#   vim       infra/docker/.env.production
#
# Required values have NO default; docker compose will refuse to start if any
# `:?` variable below is missing or empty. That refusal is intentional — it
# guarantees no production deployment can boot with a weak secret.
#
# Generate strong secrets with:
#   openssl rand -base64 48      # 64-char URL-safe — good for JWT/SESSION
#   openssl rand -hex   32       # 64-char hex      — good for SERVICE token
#   openssl rand -base64 24      # 32-char         — good for DB password
# =============================================================================

# ----- runtime --------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info
# Pin a build to deploy (matches `image: datalens/*:${DATALENS_VERSION}`).
DATALENS_VERSION=latest

# ----- public URLs / hostnames ----------------------------------------------
# The HTTPS origin the browser uses. MUST be reachable from the user's browser
# AND match the cert in TLS_CERT_DIR.
PUBLIC_HOSTNAME=datalens.example.com
NEXT_PUBLIC_API_URL=https://datalens.example.com
NEXT_PUBLIC_MCP_URL=https://datalens.example.com
# Comma-separated CORS origins. Production must NOT include `*`.
API_CORS_ORIGINS=https://datalens.example.com

# ----- TLS ------------------------------------------------------------------
# Directory on the host containing:
#   fullchain.pem  (cert + intermediate)
#   privkey.pem    (private key, mode 0600)
# Mounted read-only at /etc/nginx/tls inside the nginx container.
# Easiest production setup is certbot writing into /etc/letsencrypt/live/<host>/
# and a symlink here. See docs/deployment/21_NGINX_SSL.md.
TLS_CERT_DIR=/etc/letsencrypt/live/datalens.example.com
HTTP_PORT=80
HTTPS_PORT=443

# ----- database -------------------------------------------------------------
POSTGRES_DB=datalens
POSTGRES_USER=datalens
# REQUIRED — must be >= 24 random chars. Never reuse from dev.
POSTGRES_PASSWORD=

# ----- redis ----------------------------------------------------------------
# REQUIRED — Redis is reachable inside the docker network only, but a password
# defends against accidental cross-stack collisions on a shared host.
REDIS_PASSWORD=
REDIS_MAXMEMORY=512mb

# ----- secrets --------------------------------------------------------------
# REQUIRED — sign auth session cookies. Must be >= 32 chars.
JWT_SECRET=
# Optional — defaults to JWT_SECRET if unset. Set this if you want to rotate
# only the session signing key without invalidating other JWTs.
SESSION_SECRET=
# REQUIRED — internal token the mcp-server and analysis-worker use to call
# privileged API endpoints (e.g. /api/admin/heartbeat). Must be >= 16 chars.
API_SERVICE_TOKEN=

# ----- upload / runtime limits ----------------------------------------------
# Max upload size accepted by the API multipart parser AND by nginx
# `client_max_body_size`. Keep both in sync — nginx is the outer gate.
#   200 MiB == 209715200 bytes
MAX_UPLOAD_BYTES=209715200
# Display value used in nginx.prod.conf via envsubst (must include unit).
NGINX_MAX_UPLOAD=200m

# Long-running operation timeouts (ms on the API side, mirrored as seconds
# in nginx via proxy_*_timeout). The nginx values are derived in
# docs/deployment/21_NGINX_SSL.md — keep them >= the API timeout.
REQUEST_TIMEOUT_MS=600000        # 10 min — default request budget
ANALYSIS_TIMEOUT_MS=1800000      # 30 min — /api/analysis/* + /api/projects/*/auto-analyze
REPORT_TIMEOUT_MS=900000         # 15 min — /api/reports/* + export rendering

# ----- queue ----------------------------------------------------------------
ANALYSIS_QUEUE_NAME=analysis

# ----- worker tuning --------------------------------------------------------
UVICORN_WORKERS=2
UVICORN_LIMIT_CONCURRENCY=64
WORKER_HEARTBEAT_INTERVAL_SEC=30

# ----- optional: MinIO (S3-compatible object store) -------------------------
# Only required when the `minio` compose profile is enabled. See
# docs/deployment/21_DOCKER_COMPOSE_PRODUCTION.md.
# MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD=

# ----- optional: telemetry / observability ----------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_SERVICE_NAME=datalens-api
