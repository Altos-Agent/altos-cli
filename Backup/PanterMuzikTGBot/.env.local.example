# ============================================================
# Panter Müzik — .env.local.example
# Copy to .env.local and fill in values for local Docker dev.
# NEVER commit .env.local to version control!
# ============================================================

# ─────────────────────────────────────────────────────────────
# Telegram Bot (required — get from @BotFather)
# ─────────────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ─────────────────────────────────────────────────────────────
# Telegram MTProto (required — get from my.telegram.org)
# ─────────────────────────────────────────────────────────────

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────

POSTGRES_USER=panter
POSTGRES_PASSWORD=panter_local_dev_password
POSTGRES_DB=panter_muzik

# Compose sets DATABASE_URL internally for the app container.
# If you override, use: postgresql+asyncpg://panter:panter_local_dev_password@db:5432/panter_muzik
# DATABASE_URL=postgresql+asyncpg://panter:panter_local_dev_password@db:5432/panter_muzik

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────

REDIS_PASSWORD=

# Compose sets REDIS_URL internally.
# REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────
# Sessions (userbot auth — copy your .session file to ./sessions/)
# ─────────────────────────────────────────────────────────────

USERBOT_SESSION_NAME=panter_muzik_session

# ─────────────────────────────────────────────────────────────
# Admin HTTP API
# ─────────────────────────────────────────────────────────────

ENABLE_ADMIN_HTTP=true
ADMIN_API_TOKEN=                          # python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_HTTP_PORT=8080

# ─────────────────────────────────────────────────────────────
# Playback
# ─────────────────────────────────────────────────────────────

DEFAULT_VOLUME=70
AUTO_LEAVE_WHEN_EMPTY=true
MAX_QUEUE_SIZE_PER_GROUP=100

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────

LOG_LEVEL=DEBUG
LOG_JSON=false

# ─────────────────────────────────────────────────────────────
# Operator
# ─────────────────────────────────────────────────────────────

OWNER_IDS=123456789

# ─────────────────────────────────────────────────────────────
# Container operation
# ─────────────────────────────────────────────────────────────

RUN_MIGRATIONS=true
RUN_PREFLIGHT=false
DRY_RUN=false

# ─────────────────────────────────────────────────────────────
# Environment
# ─────────────────────────────────────────────────────────────

ENVIRONMENT=development