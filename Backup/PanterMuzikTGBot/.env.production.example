# ============================================================
# Panter Müzik — .env.production.example
# Copy to .env.production and fill in values.
# NEVER commit .env.production to version control!
# ============================================================

# ─────────────────────────────────────────────────────────────
# Telegram Bot (required)
# ─────────────────────────────────────────────────────────────

TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz123456
TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# ─────────────────────────────────────────────────────────────
# Database (required)
# ─────────────────────────────────────────────────────────────

DATABASE_URL=postgresql+asyncpg://panter:CHANGEME@db:5432/panter_muzik

# ─────────────────────────────────────────────────────────────
# Redis (required)
# ─────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379/0
# REDIS_PASSWORD=                  # optional, uncomment if redis requires auth

# ─────────────────────────────────────────────────────────────
# Sessions (required for userbot VC joining)
# ─────────────────────────────────────────────────────────────

USERBOT_SESSION_NAME=panter_muzik_session
# USERBOT_SESSION_STRING=           # alternative to file-based auth; generate once

# ─────────────────────────────────────────────────────────────
# Admin HTTP API (optional)
# ─────────────────────────────────────────────────────────────

ENABLE_ADMIN_HTTP=false
ADMIN_API_TOKEN=                          # generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_HTTP_PORT=8080

# ─────────────────────────────────────────────────────────────
# Playback defaults
# ─────────────────────────────────────────────────────────────

DEFAULT_VOLUME=70
AUTO_LEAVE_WHEN_EMPTY=true
MAX_TRACK_DURATION_SECONDS=600
MAX_QUEUE_SIZE_PER_GROUP=100

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
LOG_JSON=false

# ─────────────────────────────────────────────────────────────
# Operator / Security
# ─────────────────────────────────────────────────────────────

OWNER_IDS=123456789,987654321

# ─────────────────────────────────────────────────────────────
# yt-dlp
# ─────────────────────────────────────────────────────────────

YTDLP_UPDATE_MODE=default

# ─────────────────────────────────────────────────────────────
# Container operation
# ─────────────────────────────────────────────────────────────

RUN_MIGRATIONS=true
RUN_PREFLIGHT=false

# ─────────────────────────────────────────────────────────────
# Development
# ─────────────────────────────────────────────────────────────

DRY_RUN=false
ENVIRONMENT=production