# ============================================================
# Panter Müzik — Local Development Environment Variables
# ============================================================
#
# Copy this file to .env.local (in the deployment/ directory)
# for local development with Docker Compose.
#
# For local dev without Docker, copy to ../.env instead.
#
# ============================================================

# ─────────────────────────────────────────────────────────────
# Telegram Bot API
# ─────────────────────────────────────────────────────────────

BOT_TOKEN=1234567890:EXAMPLE_bot_token_for_local_dev

# ─────────────────────────────────────────────────────────────
# Telegram MTProto (Userbot)
# ─────────────────────────────────────────────────────────────

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=0123456789abcdef0123456789abcdef

# Local session file
USERBOT_SESSION_NAME=panter_muzik_session_dev

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────

POSTGRES_USER=panter_dev
POSTGRES_PASSWORD=panter_dev
POSTGRES_DB=panter_muzik_dev
DATABASE_URL=postgresql+asyncpg://panter_dev:panter_dev@db:5432/panter_muzik_dev

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────

LOG_LEVEL=DEBUG
LOG_JSON=false

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────

ENVIRONMENT=development
DRY_RUN=false

# ─────────────────────────────────────────────────────────────
# Operator
# ─────────────────────────────────────────────────────────────

# Your Telegram user ID (find it via @userinfobot)
OWNER_IDS=111111111

# ─────────────────────────────────────────────────────────────
# Playback
# ─────────────────────────────────────────────────────────────

DEFAULT_VOLUME=70
AUTO_LEAVE_WHEN_EMPTY=true
AUTO_LEAVE_IDLE_SECONDS=60
