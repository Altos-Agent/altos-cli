# ============================================================
# Panter Müzik — Production Environment Variables
# ============================================================
#
# Copy this file to .env.production (in the deployment/ directory)
# and fill in all values. This file is SAFE to commit as a
# reference — it contains no real secrets.
#
# IMPORTANT: .env.production MUST be in .gitignore and NEVER
# committed to version control.
#
# ============================================================

# ─────────────────────────────────────────────────────────────
# Telegram Bot API
# ─────────────────────────────────────────────────────────────

# Bot token from @BotFather
# Example: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=

# ─────────────────────────────────────────────────────────────
# Telegram MTProto (Userbot)
# ─────────────────────────────────────────────────────────────

# API ID from my.telegram.org
# Example: 123456
TELEGRAM_API_ID=

# API Hash from my.telegram.org
# Example: abcdef1234567890abcdef1234567890
TELEGRAM_API_HASH=

# Userbot session name (filename base for session storage)
USERBOT_SESSION_NAME=panter_muzik_session

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────

# PostgreSQL credentials (match the values in docker-compose.yml env)
POSTGRES_USER=panter
POSTGRES_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
POSTGRES_DB=panter_muzik

# Full async connection string (used by the app)
DATABASE_URL=postgresql+asyncpg://panter:CHANGE_ME_TO_A_STRONG_PASSWORD@db:5432/panter_muzik

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────

REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Set to true for machine-readable JSON logs
LOG_JSON=false

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────

ENVIRONMENT=production

# Dry run skips Telegram/DB/Redis connections
# Set to false for production
DRY_RUN=false

# ─────────────────────────────────────────────────────────────
# Operator (Bot Owner)
# ─────────────────────────────────────────────────────────────

# Telegram user IDs of bot owners (comma-separated)
# These users have full admin access
OWNER_IDS=

# ─────────────────────────────────────────────────────────────
# Playback
# ─────────────────────────────────────────────────────────────

DEFAULT_VOLUME=70
AUTO_LEAVE_WHEN_EMPTY=true
AUTO_LEAVE_IDLE_SECONDS=300

# ─────────────────────────────────────────────────────────────
# Volumes (mount paths — do not change)
# ─────────────────────────────────────────────────────────────

# Named volumes are managed by docker-compose.
# For bind mounts use these paths on the host:
# SESSIONS_DIR=/opt/panter-muzik/sessions
# CACHE_DIR=/opt/panter-muzik/cache
# LOGS_DIR=/opt/panter-muzik/logs
