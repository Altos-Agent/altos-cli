{
  "name": "@base-orchestrator/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "vitest run integration",
    "e2e:server": "tsx src/e2e-server.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "db:seed": "tsx src/db/seed.ts",
    "demo:seed": "tsx src/db/demo-seed.ts",
    "demo:reset": "tsx src/db/demo-reset.ts",
    "wallet:import": "tsx src/cli/wallet-import.ts",
    "auth:hash-password": "tsx src/cli/auth-hash-password.ts",
    "load-test": "tsx src/cli/dry-run-load-test.ts"
  },
  "dependencies": {
    "@base-orchestrator/shared": "workspace:*",
    "argon2": "^0.44.0",
    "bullmq": "^5.76.6",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "ethers": "^6.13.5",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "viem": "^2.23.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.30.2",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}
