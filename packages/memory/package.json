{
  "name": "@altos/memory",
  "version": "0.1.0",
  "type": "module",
  "description": "Altos memory system - conversation history, embeddings, vector stores",
  "license": "Apache-2.0",
  "dependencies": {
    "@altos/core": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./store": {
      "types": "./dist/store/index.d.ts",
      "default": "./dist/store/index.js"
    },
    "./embeddings": {
      "types": "./dist/embeddings/index.d.ts",
      "default": "./dist/embeddings/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "default": "./dist/events/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
