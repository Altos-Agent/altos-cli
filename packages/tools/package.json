{
  "name": "@altos/tools",
  "version": "0.1.0",
  "type": "module",
  "description": "Altos built-in tools - filesystem, git, shell, search, etc.",
  "license": "Apache-2.0",
  "exports": {
    ".": "./dist/index.js",
    "./fs": "./dist/fs/index.js",
    "./git": "./dist/git/index.js",
    "./shell": "./dist/shell/index.js",
    "./search": "./dist/search/index.js"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "lint": "biome lint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@altos/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
